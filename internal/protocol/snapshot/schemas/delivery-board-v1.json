{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baton.sawy3r.net/schemas/delivery-board-v1.json",
  "title": "Baton delivery board projection v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "delivery_id",
    "plan_digest",
    "source_revision",
    "state",
    "work"
  ],
  "properties": {
    "schema_version": { "const": "delivery-board-v1" },
    "delivery_id": { "$ref": "#/$defs/id" },
    "plan_digest": { "$ref": "#/$defs/digest" },
    "source_revision": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "state": {
      "enum": ["planned", "active", "attention", "verified", "ready_to_integrate", "integrating", "integrated"]
    },
    "work": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/work_projection" }
    },
    "attention": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "state": { "const": "integrated" } } },
      "then": {
        "properties": {
          "work": {
            "items": {
              "allOf": [
                { "$ref": "#/$defs/work_projection" },
                { "properties": { "state": { "const": "integrated" } } }
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$(?![\\s\\S])"
    },
    "non_empty": { "type": "string", "minLength": 1, "pattern": "\\S" },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$(?![\\s\\S])"
    },
    "oid": {
      "type": "string",
      "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$(?![\\s\\S])"
    },
    "work_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "state", "attempt", "next_action"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "state": {
          "enum": [
            "waiting",
            "ready",
            "active",
            "attention",
            "reviewable",
            "repair",
            "blocked",
            "retry",
            "verified",
            "ready_to_integrate",
            "integrating",
            "integrated"
          ]
        },
        "attempt": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "submission_id": { "$ref": "#/$defs/id" },
        "submission_digest": { "$ref": "#/$defs/digest" },
        "candidate_commit": { "$ref": "#/$defs/oid" },
        "verdict_id": { "$ref": "#/$defs/id" },
        "verdict_digest": { "$ref": "#/$defs/digest" },
        "verdict": { "enum": ["PASS", "FAIL", "SPEC_BLOCK", "INCONCLUSIVE"] },
        "next_action": {
          "enum": ["wait", "build", "verify", "repair", "replan", "retry_verification", "integrate", "none"]
        },
        "attention": { "$ref": "#/$defs/non_empty" }
      },
      "allOf": [
        {
          "if": { "properties": { "state": { "const": "waiting" } } },
          "then": { "properties": { "next_action": { "const": "wait" } } }
        },
        {
          "if": { "properties": { "state": { "const": "ready" } } },
          "then": { "properties": { "next_action": { "const": "build" } } }
        },
        {
          "if": { "properties": { "state": { "const": "active" } } },
          "then": { "properties": { "next_action": { "const": "wait" } } }
        },
        {
          "if": { "properties": { "state": { "const": "attention" } } },
          "then": {
            "required": ["attention"],
            "properties": { "next_action": { "const": "replan" } }
          }
        },
        {
          "if": { "properties": { "state": { "const": "reviewable" } } },
          "then": {
            "required": ["submission_id", "submission_digest", "candidate_commit"],
            "properties": { "next_action": { "const": "verify" } }
          }
        },
        {
          "if": { "properties": { "state": { "const": "repair" } } },
          "then": {
            "required": ["submission_id", "submission_digest", "candidate_commit", "verdict_id", "verdict_digest", "verdict"],
            "properties": {
              "verdict": { "const": "FAIL" },
              "next_action": { "const": "repair" }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "blocked" } } },
          "then": {
            "required": ["submission_id", "submission_digest", "candidate_commit", "verdict_id", "verdict_digest", "verdict", "attention"],
            "properties": {
              "verdict": { "const": "SPEC_BLOCK" },
              "next_action": { "const": "replan" }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "retry" } } },
          "then": {
            "required": ["submission_id", "submission_digest", "candidate_commit", "verdict_id", "verdict_digest", "verdict"],
            "properties": {
              "verdict": { "const": "INCONCLUSIVE" },
              "next_action": { "const": "retry_verification" }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "verified" } } },
          "then": {
            "required": ["submission_id", "submission_digest", "candidate_commit", "verdict_id", "verdict_digest", "verdict"],
            "properties": {
              "verdict": { "const": "PASS" },
              "next_action": { "const": "replan" }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "ready_to_integrate" } } },
          "then": {
            "required": ["submission_id", "submission_digest", "candidate_commit", "verdict_id", "verdict_digest", "verdict"],
            "properties": {
              "verdict": { "const": "PASS" },
              "next_action": { "const": "integrate" }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "integrating" } } },
          "then": {
            "required": ["submission_id", "submission_digest", "candidate_commit", "verdict_id", "verdict_digest", "verdict"],
            "properties": {
              "verdict": { "const": "PASS" },
              "next_action": { "const": "wait" }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "integrated" } } },
          "then": {
            "required": ["submission_id", "submission_digest", "candidate_commit", "verdict_id", "verdict_digest", "verdict"],
            "properties": {
              "verdict": { "const": "PASS" },
              "next_action": { "const": "none" }
            }
          }
        }
      ]
    }
  }
}
