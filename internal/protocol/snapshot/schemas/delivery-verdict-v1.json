{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baton.sawy3r.net/schemas/delivery-verdict-v1.json",
  "title": "Baton delivery verdict v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "verdict_id",
    "submission_id",
    "submission_digest",
    "delivery_id",
    "work_id",
    "review",
    "outcome",
    "summary",
    "acceptance_results",
    "assurance_results",
    "findings"
  ],
  "properties": {
    "schema_version": { "const": "delivery-verdict-v1" },
    "verdict_id": { "$ref": "#/$defs/id" },
    "submission_id": { "$ref": "#/$defs/id" },
    "submission_digest": { "$ref": "#/$defs/digest" },
    "delivery_id": { "$ref": "#/$defs/id" },
    "work_id": { "$ref": "#/$defs/id" },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "agent", "fresh_context", "dispatch_receipt", "started_at", "completed_at"],
      "properties": {
        "run_id": { "$ref": "#/$defs/id" },
        "agent": { "$ref": "#/$defs/non_empty" },
        "fresh_context": { "const": true },
        "dispatch_receipt": { "$ref": "#/$defs/artifact" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" }
      }
    },
    "outcome": { "enum": ["PASS", "FAIL", "SPEC_BLOCK", "INCONCLUSIVE"] },
    "summary": { "$ref": "#/$defs/non_empty" },
    "acceptance_results": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/acceptance_result" }
    },
    "assurance_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/assurance_result" }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "outcome": { "const": "PASS" } } },
      "then": {
        "properties": {
          "acceptance_results": {
            "items": {
              "allOf": [
                { "$ref": "#/$defs/acceptance_result" },
                {
                  "properties": {
                    "outcome": { "const": "pass" },
                    "evidence_ids": { "minItems": 1 }
                  }
                }
              ]
            }
          },
          "assurance_results": {
            "items": {
              "allOf": [
                { "$ref": "#/$defs/assurance_result" },
                {
                  "properties": {
                    "outcome": { "const": "pass" },
                    "evidence_ids": { "minItems": 1 }
                  }
                }
              ]
            }
          },
          "findings": {
            "not": {
              "contains": {
                "properties": { "severity": { "const": "blocking" } },
                "required": ["severity"]
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "outcome": { "const": "FAIL" } } },
      "then": {
        "properties": {
          "findings": {
            "contains": {
              "properties": {
                "severity": { "const": "blocking" },
                "kind": { "enum": ["implementation", "evidence", "composition"] }
              },
              "required": ["severity", "kind"]
            },
            "not": {
              "contains": {
                "properties": {
                  "severity": { "const": "blocking" },
                  "kind": { "enum": ["authority", "contract", "environment"] }
                },
                "required": ["severity", "kind"]
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "outcome": { "const": "SPEC_BLOCK" } } },
      "then": {
        "properties": {
          "findings": {
            "contains": {
              "properties": {
                "severity": { "const": "blocking" },
                "kind": { "enum": ["authority", "contract"] }
              },
              "required": ["severity", "kind"]
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "outcome": { "const": "INCONCLUSIVE" } } },
      "then": {
        "properties": {
          "findings": {
            "contains": {
              "properties": {
                "severity": { "const": "blocking" },
                "kind": { "enum": ["evidence", "environment"] }
              },
              "required": ["severity", "kind"]
            },
            "not": {
              "contains": {
                "properties": {
                  "severity": { "const": "blocking" },
                  "kind": { "enum": ["authority", "contract"] }
                },
                "required": ["severity", "kind"]
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$(?![\\s\\S])"
    },
    "non_empty": { "type": "string", "minLength": 1, "pattern": "\\S" },
    "pack_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}@[A-Za-z0-9][A-Za-z0-9._-]{0,31}$(?![\\s\\S])"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$(?![\\s\\S])"
    },
    "media_type": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9!#$&^_.+-]{0,126}/[a-z0-9][a-z0-9!#$&^_.+-]{0,126}$(?![\\s\\S])"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "media_type", "digest"],
      "properties": {
        "ref": { "$ref": "#/$defs/non_empty" },
        "media_type": { "$ref": "#/$defs/media_type" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "acceptance_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptance_id", "outcome", "evidence_ids", "summary"],
      "properties": {
        "acceptance_id": { "$ref": "#/$defs/id" },
        "outcome": { "enum": ["pass", "fail", "inconclusive"] },
        "evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "summary": { "$ref": "#/$defs/non_empty" }
      }
    },
    "assurance_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pack", "outcome", "evidence_ids", "summary"],
      "properties": {
        "pack": { "$ref": "#/$defs/pack_id" },
        "outcome": { "enum": ["pass", "fail", "inconclusive"] },
        "evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "summary": { "$ref": "#/$defs/non_empty" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "principle", "severity", "summary", "acceptance_ids", "evidence_ids"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": {
          "enum": ["authority", "contract", "implementation", "evidence", "environment", "composition"]
        },
        "principle": { "enum": ["B1", "B2", "B3", "B4", "B5"] },
        "severity": { "enum": ["blocking", "non_blocking"] },
        "summary": { "$ref": "#/$defs/non_empty" },
        "acceptance_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    }
  }
}
