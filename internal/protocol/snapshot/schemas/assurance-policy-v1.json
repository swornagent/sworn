{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baton.sawy3r.net/schemas/assurance-policy-v1.json",
  "title": "Baton assurance policy registry v1",
  "description": "A non-record registry of content-addressed Standard checks and assurance-pack definitions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy_id", "checks", "packs"],
  "properties": {
    "schema_version": { "const": "assurance-policy-v1" },
    "policy_id": { "$ref": "#/$defs/id" },
    "checks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/check" }
    },
    "packs": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/pack" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$(?![\\s\\S])"
    },
    "pack_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}@[A-Za-z0-9][A-Za-z0-9._-]{0,31}$(?![\\s\\S])"
    },
    "non_empty": { "type": "string", "minLength": 1, "pattern": "\\S" },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$(?![\\s\\S])"
    },
    "definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "media_type", "digest"],
      "properties": {
        "ref": { "$ref": "#/$defs/non_empty" },
        "media_type": { "const": "application/json" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "definition"],
      "properties": {
        "id": { "$ref": "#/$defs/pack_id" },
        "definition": { "$ref": "#/$defs/definition" }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "definition"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "definition": { "$ref": "#/$defs/definition" }
      }
    }
  }
}
