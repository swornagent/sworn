  "engine_cases": [
    {
      "id": "derive-git-candidate-facts",
      "principles": ["B1", "B3", "B5"],
      "requires": "real Git object database",
      "expect": "Prove repository identity, base ancestry, exact tree diff, rename scope, cleanliness, and candidate retention from Git facts."
    },
    {
      "id": "contain-builder-and-verifier",
      "principles": ["B1", "B4"],
      "requires": "real subprocess and sandbox",
      "expect": "Attempts to change parent paths, target refs, remotes, credentials, or leave child processes alive fail without side effects."
    },
    {
      "id": "candidate-change-invalidates-pass",
      "principles": ["B3", "B4", "B5"],
      "requires": "real Git and verifier dispatch",
      "expect": "Any candidate commit, tree, index, or tracked-byte change requires a new submission and verifier run."
    },
    {
      "id": "authority-revocation-before-integration",
      "principles": ["B1", "B5"],
      "requires": "real authority resolver",
      "expect": "Re-resolve the source immediately before integration and stop on expiry, revocation, digest drift, or a missing exact grant."
    },
    {
      "id": "target-movement-refuses-integration",
      "principles": ["B5"],
      "requires": "real compare-and-swap target update",
      "expect": "A moved target is never overwritten, rebased, merged, or silently composed under the old verdict."
    },
    {
      "id": "board-is-derived",
      "principles": ["B2"],
      "requires": "real persistence and board projection",
      "expect": "Editing a rendered board cannot change state; replaying the same durable facts produces the same semantic projection."
    },
    {
      "id": "integration-recovery-is-idempotent",
      "principles": ["B2", "B5"],
      "requires": "crash injection around target compare-and-swap",
      "expect": "After a crash, reconcile an equal or descendant target first, record one completion, and never issue a duplicate integration."
    },
    {
      "id": "persistence-failure-never-projects-success",
      "principles": ["B2", "B5"],
      "requires": "real persistence fault injection",
      "expect": "A failed durable record or effect receipt prevents verified or integrated projection."
    },
    {
      "id": "typed-outcome-routing",
      "principles": ["B1", "B4"],
      "requires": "real reducer and runner invocations",
      "expect": "FAIL repairs, SPEC_BLOCK requests authority or contract attention, and INCONCLUSIVE re-verifies the unchanged submission."
    },
    {
      "id": "record-identities-are-write-once",
      "principles": ["B2", "B4"],
      "requires": "real durable persistence and replay",
      "expect": "Reusing a submission or verdict ID for different canonical bytes is rejected across restarts and concurrent commands."
    },
    {
      "id": "authority-delegation-never-enlarges-plan",
      "principles": ["B1"],
      "requires": "real authority resolver and local policy",
      "expect": "Standing scope, protected paths, assurance floors, and grant ceilings are enforced; local configuration cannot grant an action absent from the exact plan."
    },
    {
      "id": "approval-is-not-self-asserted",
      "principles": ["B1"],
      "requires": "real authorizer trust root or capability and runner isolation",
      "expect": "Caller-written identity claims, synthetic TTY approval, forged proof, and runner-writable source replacement fail; valid approval requires an authorizer capability unavailable to caller, builder, and verifier."
    },
    {
      "id": "verifier-control-is-engine-owned",
      "principles": ["B4"],
      "requires": "real native runner and candidate-local hostile configuration",
      "expect": "Candidate AGENTS, CLAUDE, MCP, plugin, hook, and callback configuration is review data only and cannot alter verifier instructions or capabilities."
    },
    {
      "id": "subprocess-resources-are-bounded",
      "principles": ["B1", "B2"],
      "requires": "real subprocess containment and resource limits",
      "expect": "PID, memory, CPU, output, wall-time, and writable-storage exhaustion stops the invocation without host damage or a false success projection."
    },
    {
      "id": "assurance-definition-semantics-are-enforced",
      "principles": ["B1", "B3", "B4"],
      "requires": "real policy definitions, producers, and verifier",
      "expect": "A selected pack cannot PASS until its bound checks, evidence requirements, verifier questions, and authority gates are satisfied by the exact candidate."
    },
    {
      "id": "required-check-failure-short-circuits-verifier",
      "principles": ["B2", "B3", "B4"],
      "requires": "real failing producer, invocation accounting, and durable store",
      "expect": "A required check failure banks its receipt and repairs before any submission, verifier invocation, or delivery verdict exists."
    },
    {
      "id": "already-satisfied-work-is-noop-safe",
      "principles": ["B2", "B3", "B5"],
      "requires": "real Git with candidate equal to base and an empty diff",
      "expect": "Already-satisfied work verifies truthfully and reconciles as already observed without forcing an unrelated or empty commit."
    },
    {
      "id": "serial-multiwork-history-remains-integrated",
      "principles": ["B2", "B5"],
      "requires": "real Git ancestry, two submissions, and board replay",
      "expect": "The dependent builder starts only after predecessor PASS from a base containing that candidate; after target advancement every integrated row retains its exact receipt and ancestry, and phantom rows are rejected."
    }
  ]
