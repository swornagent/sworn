{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baton.sawy3r.net/schemas/slice-status-v1.json",
  "title": "Baton Slice Status",
  "description": "Machine-readable state for one Baton release-mode slice.",
  "type": "object",
  "additionalProperties": true,
  "required": ["slice_id", "release", "state", "start_commit", "verification", "maintainability"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://baton.sawy3r.net/schemas/slice-status-v1.json"
    },
    "slice_id": {
      "type": "string",
      "minLength": 1
    },
    "release": {
      "type": "string",
      "minLength": 1
    },
    "track": {
      "type": "string"
    },
    "covers_needs": {
      "type": "array",
      "description": "Intake need IDs (N-01, N-02, ...) this slice delivers. The RTM gate verifies every intake need appears in at least one slice's covers_needs.",
      "items": { "type": "string", "pattern": "^N-\\d+$" }
    },
    "state": {
      "type": "string",
      "enum": [
        "planned",
        "design_review",
        "in_progress",
        "implemented",
        "verified",
        "failed_verification",
        "blocked",
        "deferred",
        "shipped"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_updated_by": {
      "type": "string"
    },
    "last_updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "start_commit": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{40}([a-f0-9]{24})?$"
    },
    "spec_path": {
      "type": "string"
    },
    "proof_path": {
      "type": "string"
    },
    "journal_path": {
      "type": "string"
    },
    "planned_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actual_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "test_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reachability_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "maintainability": {
      "type": "object",
      "additionalProperties": false,
      "description": "Bounded maintainability lifecycle state. cycle 0 is the initial Implementer preflight/remediation/closure cycle; cycle 1 is the only Coach-approved resume. The fresh Verifier appends its authoritative report. A second repeated closure failure requires re-slicing.",
      "required": ["state", "cycle", "implementation_head", "rollback_slice_id", "reports", "adjudication"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["pending", "passed", "needs_coach", "resume_approved", "re_slice_required"]
        },
        "cycle": { "type": "integer", "minimum": 0, "maximum": 1 },
        "implementation_head": {
          "description": "Immutable committed head of the semantic implementation approved by the final Implementer maintainability PASS. The fresh Verifier reviews this commit even after later release-wt synchronization merges.",
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{40}([a-f0-9]{24})?$"
        },
        "rollback_slice_id": {
          "description": "Planner-created rollback slice. Ordinary maintainability failure restores the failed semantic paths to start_commit; deterministic post-sync invalidation restores the invalidated reviewed candidate paths to the recorded recognized synchronization parent-2 baseline before replacements begin.",
          "type": ["string", "null"],
          "minLength": 1
        },
        "reports": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "phase", "cycle", "invocation_id", "report_path", "report_blob_oid", "review_scope_head", "input_fingerprint", "verdict", "blocking_finding_ids"],
            "properties": {
              "role": { "type": "string", "enum": ["implementer", "verifier"] },
              "phase": { "type": "string", "enum": ["preflight", "closure", "authoritative"] },
              "cycle": { "type": "integer", "minimum": 0, "maximum": 1 },
              "invocation_id": { "type": "string", "minLength": 1 },
              "report_path": { "type": "string", "minLength": 1 },
              "report_blob_oid": {
                "type": "string",
                "pattern": "^[a-f0-9]{40}([a-f0-9]{24})?$"
              },
              "review_scope_head": {
                "type": "string",
                "pattern": "^[a-f0-9]{40}([a-f0-9]{24})?$"
              },
              "input_fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
              "verdict": { "type": "string", "enum": ["PASS", "FAIL"] },
              "blocking_finding_ids": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            },
            "allOf": [
              {
                "if": { "properties": { "role": { "const": "implementer" } }, "required": ["role"] },
                "then": { "properties": { "phase": { "enum": ["preflight", "closure"] } } }
              },
              {
                "if": { "properties": { "role": { "const": "verifier" } }, "required": ["role"] },
                "then": { "properties": { "phase": { "const": "authoritative" } } }
              },
              {
                "if": { "properties": { "verdict": { "const": "PASS" } }, "required": ["verdict"] },
                "then": { "properties": { "blocking_finding_ids": { "maxItems": 0 } } }
              },
              {
                "if": { "properties": { "verdict": { "const": "FAIL" } }, "required": ["verdict"] },
                "then": { "properties": { "blocking_finding_ids": { "minItems": 1 } } }
              }
            ]
          },
          "allOf": [
            {
              "if": {
                "contains": {
                  "properties": { "phase": { "const": "closure" }, "cycle": { "const": 0 } },
                  "required": ["phase", "cycle"]
                }
              },
              "then": {
                "contains": {
                  "properties": { "role": { "const": "implementer" }, "phase": { "const": "preflight" }, "cycle": { "const": 0 }, "verdict": { "const": "FAIL" } },
                  "required": ["role", "phase", "cycle", "verdict"]
                }
              }
            },
            {
              "if": {
                "contains": {
                  "properties": { "phase": { "const": "closure" }, "cycle": { "const": 1 } },
                  "required": ["phase", "cycle"]
                }
              },
              "then": {
                "contains": {
                  "properties": { "role": { "const": "implementer" }, "phase": { "const": "preflight" }, "cycle": { "const": 1 }, "verdict": { "const": "FAIL" } },
                  "required": ["role", "phase", "cycle", "verdict"]
                }
              }
            },
            {
              "if": {
                "contains": {
                  "properties": { "role": { "const": "verifier" }, "phase": { "const": "authoritative" }, "cycle": { "const": 0 } },
                  "required": ["role", "phase", "cycle"]
                }
              },
              "then": {
                "contains": {
                  "properties": { "role": { "const": "implementer" }, "cycle": { "const": 0 }, "verdict": { "const": "PASS" } },
                  "required": ["role", "cycle", "verdict"]
                }
              }
            },
            {
              "if": {
                "contains": {
                  "properties": { "role": { "const": "verifier" }, "phase": { "const": "authoritative" }, "cycle": { "const": 1 } },
                  "required": ["role", "phase", "cycle"]
                }
              },
              "then": {
                "contains": {
                  "properties": { "role": { "const": "implementer" }, "cycle": { "const": 1 }, "verdict": { "const": "PASS" } },
                  "required": ["role", "cycle", "verdict"]
                }
              }
            }
          ]
        },
        "adjudication": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["decision", "report_invocation_ids", "report_fingerprints", "blocking_finding_ids", "rationale", "approved_by", "approved_at"],
              "properties": {
                "decision": { "type": "string", "enum": ["resume_in_scope", "re_slice"] },
                "report_invocation_ids": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 2,
                  "items": { "type": "string", "minLength": 1 },
                  "uniqueItems": true
                },
                "report_fingerprints": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 2,
                  "items": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
                },
                "blocking_finding_ids": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 },
                  "uniqueItems": true
                },
                "permitted_touchpoints": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 },
                  "uniqueItems": true
                },
                "rationale": { "type": "string", "minLength": 1 },
                "approved_by": { "type": "string", "minLength": 1 },
                "approved_at": { "type": "string", "format": "date-time" }
              },
              "allOf": [
                {
                  "if": { "properties": { "decision": { "const": "resume_in_scope" } }, "required": ["decision"] },
                  "then": { "required": ["permitted_touchpoints"] }
                },
                {
                  "if": { "properties": { "decision": { "const": "resume_in_scope" } }, "required": ["decision"] },
                  "then": {
                    "properties": {
                      "report_invocation_ids": { "minItems": 2 },
                      "report_fingerprints": { "minItems": 2 }
                    }
                  }
                }
              ]
            }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "state": { "const": "pending" } }, "required": ["state"] },
          "then": {
            "properties": {
              "cycle": { "const": 0 },
              "implementation_head": { "type": "null" },
              "rollback_slice_id": { "type": "null" },
              "adjudication": { "type": "null" },
              "reports": {
                "maxItems": 1,
                "items": {
                  "properties": {
                    "role": { "const": "implementer" },
                    "phase": { "const": "preflight" },
                    "cycle": { "const": 0 },
                    "verdict": { "const": "FAIL" }
                  }
                }
              }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "needs_coach" } }, "required": ["state"] },
          "then": {
            "properties": {
              "cycle": { "const": 0 },
              "implementation_head": { "type": "null" },
              "rollback_slice_id": { "type": "null" },
              "reports": { "minItems": 1 },
              "adjudication": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "resume_approved" } }, "required": ["state"] },
          "then": {
            "properties": {
              "cycle": { "const": 1 },
              "implementation_head": { "type": "null" },
              "rollback_slice_id": { "type": "null" },
              "reports": { "minItems": 2 },
              "adjudication": {
                "type": "object",
                "properties": { "decision": { "const": "resume_in_scope" } },
                "required": ["decision"]
              }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "passed" } }, "required": ["state"] },
          "then": {
            "properties": {
              "implementation_head": { "type": "string" },
              "rollback_slice_id": { "type": "null" },
              "reports": { "minItems": 1 }
            }
          }
        },
        {
          "if": { "properties": { "state": { "const": "re_slice_required" } }, "required": ["state"] },
          "then": {
            "properties": {
              "implementation_head": { "type": "null" },
              "reports": { "minItems": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reports": {
                "contains": {
                  "properties": { "cycle": { "const": 1 } },
                  "required": ["cycle"]
                }
              }
            },
            "required": ["reports"]
          },
          "then": {
            "properties": {
              "cycle": { "const": 1 },
              "adjudication": {
                "type": "object",
                "properties": { "decision": { "const": "resume_in_scope" } },
                "required": ["decision"]
              }
            }
          }
        }
      ]
    },
    "open_deferrals": {
      "type": "array",
      "description": "Rule 2 deferral objects. Each must carry why, tracking, acknowledgement, and acknowledged_by (acknowledged_at optional) per the No Silent Deferrals rule. acknowledgement is the plain-text evidence the decision-maker was told; acknowledged_by is the structured attribution (who); acknowledged_at is when. This is STRICT ADDITIVE: acknowledged_by is in addition to acknowledgement, not an either-or substitute (a name is not the plain-text 'told' evidence Rule 2 requires).",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["why", "tracking", "acknowledgement", "acknowledged_by"],
        "properties": {
          "item": { "type": "string" },
          "why": { "type": "string", "minLength": 1 },
          "tracking": { "type": "string", "minLength": 1 },
          "acknowledgement": { "type": "string", "minLength": 1 },
          "acknowledged_by": { "type": "string", "minLength": 1 },
          "acknowledged_at": { "type": "string", "minLength": 1 }
        }
      }
    },
    "effort_complexity": {
      "type": "object",
      "additionalProperties": false,
      "description": "The implementer-confirmed mirror of spec-v1.effort_complexity (ADR-0011 §3.7). confirmed_by_implementer flips true once the implementer has reviewed the planner's rating against code reality; a divergence from the spec rating is itself a Rule-8 signal the spec was thin.",
      "required": ["effort", "complexity", "quadrant"],
      "properties": {
        "effort": { "type": "string", "enum": ["low", "high"] },
        "complexity": { "type": "string", "enum": ["low", "high"] },
        "quadrant": { "type": "string", "enum": ["quick", "grind", "puzzle", "beast"] },
        "rationale": { "type": "string" },
        "confirmed_by_implementer": { "type": "boolean" }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": true,
      "required": ["result"],
      "properties": {
        "result": {
          "type": ["string", "null"],
          "enum": ["pending", "pass", "fail", "blocked", "inconclusive", null]
        },
        "verifier_session_id": {
          "type": ["string", "null"]
        },
        "verifier_verdict_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "verifier_was_fresh_context": {
          "type": ["boolean", "null"]
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "dependentRequired": {
              "invalidating_sync_merge": ["rollback_baseline_commit", "invalidated_review_head"],
              "rollback_baseline_commit": ["invalidating_sync_merge", "invalidated_review_head"],
              "invalidated_review_head": ["invalidating_sync_merge", "rollback_baseline_commit"]
            },
            "properties": {
              "gate": { "type": "string" },
              "description": { "type": "string" },
              "evidence": { "type": "string" },
              "proposed_amendment": { "type": "string" },
              "invalidating_sync_merge": {
                "description": "Recognized release-wt synchronization merge that invalidated a previously verified path during track integration.",
                "type": "string",
                "pattern": "^[a-f0-9]{40}([a-f0-9]{24})?$"
              },
              "rollback_baseline_commit": {
                "description": "Exact parent-2 commit of invalidating_sync_merge whose tree a post-sync rollback must preserve.",
                "type": "string",
                "pattern": "^[a-f0-9]{40}([a-f0-9]{24})?$"
              },
              "invalidated_review_head": {
                "description": "Former implementation_head whose candidate paths were invalidated. Must equal the newest authoritative PASS review_scope_head and remains the rollback scope head after implementation_head is cleared.",
                "type": "string",
                "pattern": "^[a-f0-9]{40}([a-f0-9]{24})?$"
              }
            }
          }
        }
      }
    },
    "release_base": {
      "type": "string"
    },
    "release_benefit": {
      "type": "string"
    },
    "org_objective": {
      "type": "string"
    },
    "validation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "human_ratified": { "type": "boolean" },
        "ratified_by": { "type": "string" },
        "ratified_at": { "type": "string", "format": "date-time" },
        "positive_scenarios": { "type": "array", "items": { "type": "string" } },
        "negative_scenarios": { "type": "array", "items": { "type": "string" } },
        "benefit_hypothesis": { "type": "string" }
      }
    },
    "design_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["choice", "stake_class"],
        "properties": {
          "choice": { "type": "string" },
          "stake_class": { "type": "string", "enum": ["Type-1", "Type-2"] },
          "options": { "type": "array", "items": { "type": "string" } },
          "human_decision": { "type": "string" },
          "rationale": { "type": "string" },
          "architecturally_significant": { "type": "boolean" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "state": { "enum": ["verified", "shipped"] },
          "maintainability": {
            "properties": { "cycle": { "const": 0 } },
            "required": ["cycle"]
          }
        },
        "required": ["state", "maintainability"]
      },
      "then": {
        "properties": {
          "maintainability": {
            "properties": {
              "reports": {
                "contains": {
                  "properties": { "role": { "const": "verifier" }, "phase": { "const": "authoritative" }, "cycle": { "const": 0 }, "verdict": { "const": "PASS" } },
                  "required": ["role", "phase", "cycle", "verdict"]
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": { "enum": ["verified", "shipped"] },
          "maintainability": {
            "properties": { "cycle": { "const": 1 } },
            "required": ["cycle"]
          }
        },
        "required": ["state", "maintainability"]
      },
      "then": {
        "properties": {
          "maintainability": {
            "properties": {
              "reports": {
                "contains": {
                  "properties": { "role": { "const": "verifier" }, "phase": { "const": "authoritative" }, "cycle": { "const": 1 }, "verdict": { "const": "PASS" } },
                  "required": ["role", "phase", "cycle", "verdict"]
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "state": { "enum": ["verified", "shipped"] } },
        "required": ["state"]
      },
      "then": {
        "properties": {
          "maintainability": {
            "properties": { "state": { "const": "passed" } },
            "required": ["state"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "maintainability": {
            "properties": { "state": { "const": "re_slice_required" } },
            "required": ["state"]
          }
        },
        "required": ["maintainability"]
      },
      "then": {
        "properties": {
          "state": { "enum": ["in_progress", "failed_verification", "deferred"] }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": { "const": "deferred" },
          "maintainability": {
            "properties": { "state": { "const": "re_slice_required" } },
            "required": ["state"]
          }
        },
        "required": ["state", "maintainability"]
      },
      "then": {
        "properties": {
          "maintainability": {
            "properties": { "rollback_slice_id": { "type": "string" } },
            "required": ["rollback_slice_id"]
          }
        }
      }
    }
  ]
}
