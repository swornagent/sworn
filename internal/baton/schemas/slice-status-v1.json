{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baton.sawy3r.net/schemas/slice-status-v1.json",
  "title": "Baton Slice Status",
  "description": "Machine-readable state for one Baton release-mode slice.",
  "type": "object",
  "additionalProperties": true,
  "required": ["slice_id", "release", "state", "verification"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://baton.sawy3r.net/schemas/slice-status-v1.json"
    },
    "slice_id": {
      "type": "string",
      "minLength": 1
    },
    "release": {
      "type": "string",
      "minLength": 1
    },
    "track": {
      "type": "string"
    },
    "covers_needs": {
      "type": "array",
      "description": "Intake need IDs (N-01, N-02, ...) this slice delivers. The RTM gate verifies every intake need appears in at least one slice's covers_needs.",
      "items": { "type": "string", "pattern": "^N-\\d+$" }
    },
    "state": {
      "type": "string",
      "enum": [
        "planned",
        "design_review",
        "in_progress",
        "implemented",
        "verified",
        "failed_verification",
        "blocked",
        "deferred",
        "shipped"
      ]
    },
    "owner": {
      "type": "string"
    },
    "last_updated_by": {
      "type": "string"
    },
    "last_updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "start_commit": {
      "type": ["string", "null"]
    },
    "spec_path": {
      "type": "string"
    },
    "proof_path": {
      "type": "string"
    },
    "journal_path": {
      "type": "string"
    },
    "planned_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actual_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "test_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reachability_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_deferrals": {
      "type": "array",
      "description": "Rule 2 deferral objects. Each must carry why, tracking, acknowledgement, and acknowledged_by (acknowledged_at optional) per the No Silent Deferrals rule. acknowledgement is the plain-text evidence the decision-maker was told; acknowledged_by is the structured attribution (who); acknowledged_at is when. This is the STRICT ADDITIVE canonical shape: acknowledged_by is in addition to acknowledgement, not an either-or substitute (a name is not the plain-text 'told' evidence Rule 2 requires).",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["why", "tracking", "acknowledgement", "acknowledged_by"],
        "properties": {
          "item": { "type": "string" },
          "why": { "type": "string", "minLength": 1 },
          "tracking": { "type": "string", "minLength": 1 },
          "acknowledgement": { "type": "string", "minLength": 1 },
          "acknowledged_by": { "type": "string", "minLength": 1 },
          "acknowledged_at": { "type": "string", "minLength": 1 }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": true,
      "required": ["result"],
      "properties": {
        "result": {
          "type": ["string", "null"],
          "enum": ["pending", "pass", "fail", "blocked", "inconclusive", null]
        },
        "verifier_session_id": {
          "type": ["string", "null"]
        },
        "verifier_verdict_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "verifier_was_fresh_context": {
          "type": ["boolean", "null"]
        },
        "violations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "gate": { "type": "string" },
              "description": { "type": "string" },
              "evidence": { "type": "string" },
              "proposed_amendment": { "type": "string" }
            }
          }
        }
      }
    },
    "release_base": {
      "type": "string"
    },
    "release_benefit": {
      "type": "string"
    },
    "org_objective": {
      "type": "string"
    },
    "validation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "human_ratified": { "type": "boolean" },
        "ratified_by": { "type": "string" },
        "ratified_at": { "type": "string", "format": "date-time" },
        "positive_scenarios": { "type": "array", "items": { "type": "string" } },
        "negative_scenarios": { "type": "array", "items": { "type": "string" } },
        "benefit_hypothesis": { "type": "string" }
      }
    },
    "design_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["choice", "stake_class"],
        "properties": {
          "choice": { "type": "string" },
          "stake_class": { "type": "string", "enum": ["Type-1", "Type-2"] },
          "options": { "type": "array", "items": { "type": "string" } },
          "human_decision": { "type": "string" },
          "rationale": { "type": "string" },
          "architecturally_significant": { "type": "boolean" }
        }
      }
    },
    "effort_complexity": {
      "type": "object",
      "description": "ADR-0011 §3.7. The implementer-confirmed mirror of spec-v1.effort_complexity. confirmed_by_implementer flips true once the implementer has reviewed the planner's rating against code reality; a divergence from the spec rating is itself a Rule-8 signal the spec was thin.",
      "additionalProperties": true,
      "required": ["effort", "complexity", "quadrant"],
      "properties": {
        "effort": { "type": "string", "enum": ["low", "high"] },
        "complexity": { "type": "string", "enum": ["low", "high"] },
        "quadrant": { "type": "string", "enum": ["chore", "grind", "puzzle", "epic"] },
        "rationale": { "type": "string" },
        "confirmed_by_implementer": { "type": "boolean" }
      }
    }
  }
}
