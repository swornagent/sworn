{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baton.sawy3r.net/schemas/spec-ambiguity-report-v1.json",
  "title": "Baton Spec Ambiguity Report",
  "description": "Structured output of the spec-ambiguity check. Findings are object members keyed by stable semantic fingerprint, so duplicate identities within a disposition are unrepresentable after duplicate-key-safe JSON parsing. Engines MUST reject duplicate raw JSON keys and any fingerprint present in both blocking_findings and advisory_findings before using the report.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "check",
    "slice_id",
    "release",
    "verdict",
    "blocking_findings",
    "advisory_findings"
  ],
  "$defs": {
    "fingerprint": {
      "type": "string",
      "minLength": 1,
      "maxLength": 192,
      "pattern": "^[a-z0-9]+(?:[._:-][a-z0-9]+)*$"
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "title",
        "detail",
        "criterion_id",
        "ambiguity_kind",
        "observable_divergence",
        "contract_surface",
        "semantic_subject",
        "suggested_resolution"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^F-[0-9]{2,}$" },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
        "title": { "type": "string", "minLength": 1 },
        "detail": { "type": "string", "minLength": 1 },
        "evidence": { "type": "string" },
        "criterion_id": { "type": "string", "minLength": 1 },
        "ambiguity_kind": {
          "type": "string",
          "enum": [
            "missing-condition",
            "missing-outcome",
            "observable-divergence",
            "contract-conflict",
            "unresolvable-reference",
            "vague-language",
            "internal-mechanics",
            "structure-or-wording"
          ]
        },
        "observable_divergence": { "type": "string", "minLength": 1 },
        "contract_surface": {
          "type": "string",
          "enum": [
            "user-visible-behavior",
            "wire-contract",
            "persisted-record",
            "security",
            "fail-closed-behavior",
            "exit-status",
            "verification-evidence",
            "reference-integrity",
            "internal-mechanics",
            "spec-structure"
          ]
        },
        "semantic_subject": {
          "description": "Stable description of the disputed condition, outcome, field, or reference. It distinguishes multiple findings with the same criterion, kind, and contract surface.",
          "type": "string",
          "minLength": 1
        },
        "suggested_resolution": { "type": "string", "minLength": 1 }
      }
    },
    "finding_map": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/fingerprint" },
      "additionalProperties": { "$ref": "#/$defs/finding" }
    }
  },
  "properties": {
    "$schema": { "type": "string", "const": "https://baton.sawy3r.net/schemas/spec-ambiguity-report-v1.json" },
    "schema_version": { "type": "integer", "const": 1 },
    "check": { "type": "string", "const": "spec-ambiguity" },
    "slice_id": { "type": "string", "minLength": 1 },
    "release": { "type": "string", "minLength": 1 },
    "verdict": { "type": "string", "enum": ["PASS", "FAIL"] },
    "blocking_findings": { "$ref": "#/$defs/finding_map" },
    "advisory_findings": { "$ref": "#/$defs/finding_map" },
    "model_id_confirmed": { "type": "string" },
    "structured_output_mode": { "type": "string", "enum": ["json_schema", "tool_call", "text_fallback"] },
    "cost_usd": { "type": "number" },
    "input_tokens": { "type": "integer" },
    "output_tokens": { "type": "integer" },
    "duration_ms": { "type": "integer" }
  },
  "allOf": [
    {
      "if": { "properties": { "verdict": { "const": "PASS" } }, "required": ["verdict"] },
      "then": { "properties": { "blocking_findings": { "maxProperties": 0 } } }
    },
    {
      "if": { "properties": { "verdict": { "const": "FAIL" } }, "required": ["verdict"] },
      "then": { "properties": { "blocking_findings": { "minProperties": 1 } } }
    }
  ]
}
