{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swornagent.dev/schemas/replacement-closure-dispatch-receipt-v1.json",
  "title": "SwornAgent planning-authority replacement closure dispatch receipt v1",
  "description": "Post-response continuity proof for the sole S02 replacement closure. The receipt reveals the random preimage whose SHA-256 was committed in the pre-dispatch claim and binds it to the claim commit and authoritative report identity.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "record_version",
    "release",
    "slice_id",
    "start_commit",
    "review_head",
    "claim_path",
    "claim_commit",
    "invocation_id",
    "continuity_token",
    "report_path",
    "report_blob_oid",
    "verdict",
    "authorization_manifest_sha256",
    "authorization_schema_sha256",
    "claim_schema_sha256",
    "receipt_schema_sha256",
    "state"
  ],
  "properties": {
    "$schema": {"const": "https://swornagent.dev/schemas/replacement-closure-dispatch-receipt-v1.json"},
    "record_version": {"const": 1},
    "release": {"const": "2026-07-15-baton-v0.16-conformance"},
    "slice_id": {"const": "S02-v015-parity-and-installs"},
    "start_commit": {"const": "e61cb190736ee7483fb4ed1a993442b26ce3574c"},
    "review_head": {"const": "2a17443d67d39cf681dba117a57673714a916d7f"},
    "claim_path": {"const": "docs/release/2026-07-15-baton-v0.16-conformance/S02-v015-parity-and-installs/replacement-closure-claim.json"},
    "claim_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "invocation_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "continuity_token": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "report_path": {"type": "string", "pattern": "^docs/release/2026-07-15-baton-v0\\.15-conformance/S02-v015-parity-and-installs/reports/maintainability/implementer-cycle-0-[0-9a-f-]{36}\\.json$"},
    "report_blob_oid": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "verdict": {"enum": ["PASS", "FAIL"]},
    "authorization_manifest_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "authorization_schema_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "claim_schema_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "receipt_schema_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "state": {"const": "response-received"}
  }
}
