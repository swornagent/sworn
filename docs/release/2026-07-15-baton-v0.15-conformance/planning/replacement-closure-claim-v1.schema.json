{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swornagent.dev/schemas/replacement-closure-claim-v1.json",
  "title": "SwornAgent planning-authority replacement closure claim v1",
  "description": "Immutable pre-dispatch consumption record for the sole S02 bootstrap replacement closure. Committing and pushing this claim consumes the one dispatch slot before any model request; a claim without an authoritative matching report requires Coach recovery and never permits automatic redispatch.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "record_version",
    "release",
    "slice_id",
    "start_commit",
    "review_head",
    "role",
    "phase",
    "cycle",
    "required_hold_commit",
    "replaces_orphan_invocation_id",
    "authorization_manifest_sha256",
    "authorization_schema_sha256",
    "claim_schema_sha256",
    "receipt_schema_sha256",
    "invocation_id",
    "continuity_token_sha256",
    "dispatch_slot",
    "state"
  ],
  "properties": {
    "$schema": {"const": "https://swornagent.dev/schemas/replacement-closure-claim-v1.json"},
    "record_version": {"const": 1},
    "release": {"const": "2026-07-15-baton-v0.15-conformance"},
    "slice_id": {"const": "S02-v015-parity-and-installs"},
    "start_commit": {"const": "e61cb190736ee7483fb4ed1a993442b26ce3574c"},
    "review_head": {"const": "2a17443d67d39cf681dba117a57673714a916d7f"},
    "role": {"const": "implementer"},
    "phase": {"const": "closure"},
    "cycle": {"const": 0},
    "required_hold_commit": {"const": "3ac42c01cca6e9227bb93092ed13813bad95aa08"},
    "replaces_orphan_invocation_id": {"const": "f4ef4f75-4dc8-48d1-a37c-d37d5f83c5ff"},
    "authorization_manifest_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "authorization_schema_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "claim_schema_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "receipt_schema_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "invocation_id": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "continuity_token_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "dispatch_slot": {"const": 1},
    "state": {"const": "consumed-before-dispatch"}
  }
}
