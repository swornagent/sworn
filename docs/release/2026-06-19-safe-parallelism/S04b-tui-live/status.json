  "design_decisions": [
    {
      "choice": "db-path-anchored",
      "stake_class": "Type-2",
      "options": ["<workspaceRoot>/.sworn/sworn.db", "XDG data dir", "config file path"],
      "human_decision": "",
      "rationale": "TUI discovers repoRoot via git; DB path is filepath.Join(repoRoot, \".sworn\", \"sworn.db\"). The run-loop creates it there. SQLite WAL supports concurrent readers."
    },
    {
      "choice": "polling-mechanism",
      "stake_class": "Type-2",
      "options": ["time.Tick goroutine", "tea.Tick chained messages"],
      "human_decision": "",
      "rationale": "tea.Tick delivers tickMsg to Update, staying within Bubble Tea's single-goroutine model. Avoids goroutine lifecycle management."
    },
    {
      "choice": "data-source-live",
      "stake_class": "Type-2",
      "options": ["status.json files", "SQLite tracks table", "both"],
      "human_decision": "",
      "rationale": "Live view reads from tracks SQLite table (tracks.started_at, current_slice, state). Board view reads status.json. Two distinct sources with different freshness characteristics."
    },
    {
      "choice": "viewlive-nesting",
      "stake_class": "Type-2",
      "options": ["sibling of viewBoard", "sub-state within viewBoard", "separate top-level state"],
      "human_decision": "",
      "rationale": "viewLive is a sibling of viewBoard in the root model's state machine. l/b toggles between them; esc returns to viewReleases from either. Clean keyboard semantics."
    },
    {
      "choice": "credits-file-path",
      "stake_class": "Type-2",
      "options": ["os.UserHomeDir()/.config/sworn/credits.json", "config.Path() directory", "XDG data dir"],
      "human_decision": "",
      "rationale": "Uses os.UserHomeDir() + /.config/sworn/credits.json matching the config pattern. Spec prescribes ~/.config/sworn/credits.json explicitly."
    }
