  "design_decisions": [
    {
      "decision": "Claude Code MEMORY.md -> linked-file resolution",
      "stake_class": "Type-2",
      "rationale": "Regex extraction of links is sufficient for known format, avoiding full Markdown parser overhead."
    },
    {
      "decision": "Flat-file harness entry splitting",
      "stake_class": "Type-2",
      "rationale": "Split by --- separators to support multi-entry flat files, using fragment in path for SHA256 disambiguation."
    },
    {
      "decision": "Embedding batch concatenation order",
      "stake_class": "Type-2",
      "rationale": "Preserve input ordering when splitting batches to ensure correct mapping of texts to embeddings."
    },
    {
      "decision": "SQLite connection lifecycle",
      "stake_class": "Type-2",
      "rationale": "Single connection per build operation is sufficient for <500-entry corpora without pooling or WAL."
    },
    {
      "decision": "API key reading at call time",
      "stake_class": "Type-2",
      "rationale": "Read key from env during Embed() to allow setting it mid-session and fail at embed time if missing."
    }
  ]
